rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userProfileExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function isTeacher() {
      return isSignedIn()
        && userProfileExists(request.auth.uid)
        && userProfile(request.auth.uid).data.role == "teacher";
    }

    function isStudentInClass(classId) {
      return isSignedIn()
        && userProfileExists(request.auth.uid)
        && userProfile(request.auth.uid).data.role == "student"
        && (
          userProfile(request.auth.uid).data.classId == classId
          || (
            userProfile(request.auth.uid).data.classIds is list
            && userProfile(request.auth.uid).data.classIds.hasAny([classId])
          )
        );
    }

    function isClassTeacher() {
      return isSignedIn()
        && resource.data.teacherId == request.auth.uid;
    }

    function isTargetClassTeacher(classId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    function hasClassId(data) {
      return data.keys().hasAny(["classId"]);
    }

    function hasClassIds(data) {
      return data.keys().hasAny(["classIds"]);
    }

    function validRole(role) {
      return role == "student" || role == "teacher";
    }

    function validProfileClass(data) {
      return (
          !hasClassId(data)
          || (
            data.role == "student"
            && data.classId is string
            && data.classId.size() > 0
            && exists(/databases/$(database)/documents/classes/$(data.classId))
          )
        )
        && (
          !hasClassIds(data)
          || (
            data.role == "student"
            && data.classIds is list
            && data.classIds.size() <= 50
          )
        );
    }

    function validProfileBase(userId, data) {
      return data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "role",
          "classId",
          "classIds",
          "appearance",
          "themeColor",
          "createdAt"
        ])
        && data.uid == userId
        && data.email is string
        && data.displayName is string
        && data.displayName.size() > 0
        && validRole(data.role)
        && validProfileClass(data)
        && validOptionalProfileAppearance(data)
        && validOptionalProfileThemeColor(data);
    }

    function validProfileCreate(userId) {
      return validProfileBase(userId, request.resource.data)
        && request.resource.data.role == "student"
        && !request.resource.data.keys().hasAny(["classId", "classIds"])
        && request.resource.data.createdAt == request.time;
    }

    function validProfileUpdate(userId) {
      return validProfileBase(userId, request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName",
          "appearance",
          "themeColor"
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && (
          (
            !request.resource.data.keys().hasAny(["createdAt"])
            && !resource.data.keys().hasAny(["createdAt"])
          )
          || request.resource.data.createdAt == resource.data.createdAt
        );
    }

    function validProfileThemePreferenceUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "appearance",
          "themeColor"
        ])
        && validOptionalProfileAppearance(request.resource.data)
        && validOptionalProfileThemeColor(request.resource.data);
    }

    function validOptionalProfileAppearance(data) {
      return !data.keys().hasAny(["appearance"])
        || validAppearance(data.appearance);
    }

    function validOptionalProfileThemeColor(data) {
      return !data.keys().hasAny(["themeColor"])
        || validThemeColor(data.themeColor);
    }

    function validClassCreate() {
      return request.resource.data.keys().hasOnly([
          "name",
          "section",
          "teacherId",
          "teacherName",
          "joinCode",
          "appearance",
          "behaviorTitle",
          "answerPolicy",
          "behaviorInstructions",
          "defaultAssignmentContext",
          "modelSettings",
          "openingMessage",
          "refusalStyle",
          "responseFormat",
          "sourceUsage",
          "studentFacingInstructions",
          "themeColor",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.section is string
        && request.resource.data.section.size() > 0
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.teacherName is string
        && request.resource.data.teacherName.size() > 0
        && validJoinCode(request.resource.data)
        && validAppearance(request.resource.data.appearance)
        && validAnswerPolicy(request.resource.data.answerPolicy)
        && request.resource.data.behaviorTitle is string
        && request.resource.data.behaviorInstructions is string
        && request.resource.data.defaultAssignmentContext is string
        && validModelSettings(request.resource.data.modelSettings)
        && request.resource.data.openingMessage is string
        && request.resource.data.refusalStyle is string
        && validResponseFormat(request.resource.data.responseFormat)
        && validSourceUsage(request.resource.data.sourceUsage)
        && request.resource.data.studentFacingInstructions is string
        && validThemeColor(request.resource.data.themeColor)
        && request.resource.data.createdAt == request.time;
    }

    function validClassUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "name",
            "section",
            "joinCode",
            "appearance",
            "answerPolicy",
            "behaviorTitle",
            "behaviorInstructions",
            "defaultAssignmentContext",
            "modelSettings",
            "openingMessage",
            "refusalStyle",
            "responseFormat",
            "sourceUsage",
            "studentFacingInstructions",
            "themeColor"
          ])
        && request.resource.data.teacherId == resource.data.teacherId
        && stableClassTeacherName()
        && stableClassCreatedAt()
        && validJoinCode(request.resource.data)
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["joinCode"])
          || validClassSettings(request.resource.data)
        );
    }

    function validClassSettings(data) {
      return data.keys().hasAll([
          "name",
          "section",
          "appearance",
          "answerPolicy",
          "behaviorTitle",
          "behaviorInstructions",
          "defaultAssignmentContext",
          "modelSettings",
          "openingMessage",
          "refusalStyle",
          "responseFormat",
          "sourceUsage",
          "studentFacingInstructions",
          "themeColor"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.section is string
        && request.resource.data.section.size() > 0
        && validAppearance(request.resource.data.appearance)
        && validAnswerPolicy(request.resource.data.answerPolicy)
        && request.resource.data.behaviorTitle is string
        && request.resource.data.defaultAssignmentContext is string
        && validModelSettings(request.resource.data.modelSettings)
        && request.resource.data.behaviorInstructions is string
        && request.resource.data.openingMessage is string
        && request.resource.data.refusalStyle is string
        && validResponseFormat(request.resource.data.responseFormat)
        && validSourceUsage(request.resource.data.sourceUsage)
        && request.resource.data.studentFacingInstructions is string
        && validThemeColor(request.resource.data.themeColor);
    }

    function validThemeColor(themeColor) {
      return themeColor is string
        && themeColor in ["purple", "indigo", "blue", "teal", "emerald", "amber", "rose"];
    }

    function validAppearance(appearance) {
      return appearance is string
        && appearance in ["light", "dark"];
    }

    function validAnswerPolicy(answerPolicy) {
      return answerPolicy is map
        && answerPolicy.keys().hasOnly([
          "doNotGiveFinalAnswers",
          "requireStudentAttemptFirst",
          "askGuidingQuestionBeforeExplaining",
          "allowWorkedExamples",
          "refuseAnswerOnlyRequests"
        ])
        && answerPolicy.doNotGiveFinalAnswers is bool
        && answerPolicy.requireStudentAttemptFirst is bool
        && answerPolicy.askGuidingQuestionBeforeExplaining is bool
        && answerPolicy.allowWorkedExamples is bool
        && answerPolicy.refuseAnswerOnlyRequests is bool;
    }

    function validSourceUsage(sourceUsage) {
      return sourceUsage is map
        && sourceUsage.keys().hasOnly([
          "useClassMaterialsFirst",
          "citeSourcePages",
          "askClarificationIfSourceUnclear",
          "preferredSourceType",
          "quoteSourcePassages"
        ])
        && sourceUsage.useClassMaterialsFirst is bool
        && sourceUsage.citeSourcePages is bool
        && sourceUsage.askClarificationIfSourceUnclear is bool
        && sourceUsage.preferredSourceType is string
        && sourceUsage.preferredSourceType.size() > 0
        && sourceUsage.quoteSourcePassages is bool;
    }

    function validModelSettings(modelSettings) {
      return modelSettings is map
        && modelSettings.keys().hasOnly([
          "modelId",
          "reasoningEffort",
          "creativity",
          "responseLength"
        ])
        && modelSettings.modelId is string
        && modelSettings.modelId.size() > 0
        && modelSettings.reasoningEffort is string
        && modelSettings.reasoningEffort in ["low", "medium", "high"]
        && modelSettings.creativity is number
        && modelSettings.creativity >= 0
        && modelSettings.creativity <= 100
        && modelSettings.responseLength is string
        && modelSettings.responseLength in ["short", "medium", "long", "extended"];
    }

    function validResponseFormat(responseFormat) {
      return responseFormat is map
        && responseFormat.keys().hasOnly([
          "oneStepAtATime",
          "endWithCheckQuestion",
          "readingLevel",
          "mathNotation"
        ])
        && responseFormat.oneStepAtATime is bool
        && responseFormat.endWithCheckQuestion is bool
        && responseFormat.readingLevel is string
        && responseFormat.readingLevel in ["simple", "standard", "advanced"]
        && responseFormat.mathNotation is string
        && responseFormat.mathNotation in ["plain", "balanced", "symbolic"];
    }

    function validJoinCode(data) {
      return !data.keys().hasAny(["joinCode"])
        || (
          data.joinCode is string
          && data.joinCode.size() == 6
          && data.joinCode.matches("^[A-Z]{6}$")
        );
    }

    function stableClassTeacherName() {
      return (
          !request.resource.data.keys().hasAny(["teacherName"])
          && !resource.data.keys().hasAny(["teacherName"])
        )
        || request.resource.data.teacherName == resource.data.teacherName;
    }

    function stableClassCreatedAt() {
      return (
          !request.resource.data.keys().hasAny(["createdAt"])
          && !resource.data.keys().hasAny(["createdAt"])
        )
        || request.resource.data.createdAt == resource.data.createdAt;
    }

    function validRosterStudent() {
      return request.resource.data.keys().hasOnly(["email", "displayName", "addedAt"])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.addedAt == request.time;
    }

    function validPresence(userId) {
      return request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "role",
          "classId",
          "online",
          "lastSeenAt",
          "updatedAt"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.role is string
        && request.resource.data.classId is string
        && request.resource.data.online is bool
        && request.resource.data.lastSeenAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isStudentVisibleMaterial(data) {
      return data.status == "ready"
        && data.activeForStudents != false
        && data.studentVisible != false
        && data.teacherOnly != true
        && !(data.visibility in ["teacher-only", "hidden"])
        && data.private != true;
    }

    function isStudentVisibleMaterialDocument(classId, materialId) {
      return isStudentVisibleMaterial(
        get(/databases/$(database)/documents/classes/$(classId)/materials/$(materialId)).data
      );
    }

    match /users/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && validProfileCreate(userId);
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (
          validProfileUpdate(userId)
          || validProfileThemePreferenceUpdate()
        );
    }

    match /userPresence/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && validPresence(userId);
      allow delete: if false;
    }

    match /teacherInvites/{inviteId} {
      allow read, write: if false;
    }

    match /classes/{classId} {
      allow create: if isTeacher()
        && validClassCreate();
      allow get: if isClassTeacher();
      allow list: if isClassTeacher();
      allow update: if isClassTeacher() && validClassUpdate();
      allow delete: if isClassTeacher();

      match /students/{studentId} {
        allow read: if isTargetClassTeacher(classId);
        allow create, update: if isTargetClassTeacher(classId) && validRosterStudent();
        allow delete: if isTargetClassTeacher(classId);
      }

      match /materials/{materialId} {
        allow read: if isTargetClassTeacher(classId)
          || (isStudentInClass(classId) && isStudentVisibleMaterial(resource.data));
        allow write: if isTargetClassTeacher(classId);

        match /chunks/{chunkId} {
          allow read: if isTargetClassTeacher(classId)
            || (isStudentInClass(classId) && isStudentVisibleMaterialDocument(classId, materialId));
          allow write: if isTargetClassTeacher(classId);
        }
      }

      match /materialJobs/{jobId} {
        allow read: if isTargetClassTeacher(classId);
        allow write: if false;
      }

      match /studentLearningProfiles/{profileId} {
        allow read: if isTargetClassTeacher(classId);
        allow write: if false;

        match /revisions/{revisionId} {
          allow read: if isTargetClassTeacher(classId);
          allow write: if false;
        }
      }

      match /teacherInsights/{rangeKey} {
        allow read: if isTargetClassTeacher(classId);
        allow write: if false;

        match /revisions/{revisionId} {
          allow read: if isTargetClassTeacher(classId);
          allow write: if false;
        }

        match /feedback/{feedbackId} {
          allow read: if isTargetClassTeacher(classId);
          allow write: if false;
        }
      }

      match /conversationReviews/{conversationId} {
        allow read: if isTargetClassTeacher(classId);
        allow write: if false;
      }

      match /conversations/{conversationId} {
        allow get, list: if isTargetClassTeacher(classId)
          || (
            isStudentInClass(classId)
            && resource.data.studentId == request.auth.uid
          );
        allow write: if false;

        match /messages/{messageId} {
          allow get, list: if isTargetClassTeacher(classId)
            || (
              isStudentInClass(classId)
              && get(/databases/$(database)/documents/classes/$(classId)/conversations/$(conversationId)).data.studentId == request.auth.uid
            );
          allow write: if false;
        }
      }
    }
  }
}
